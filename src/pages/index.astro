---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import "../styles/landing.css";
import BrowserFrame from "../components/landing/BrowserFrame.astro";
import EcosystemSection from "../components/landing/EcosystemSection.astro";
import FeatureCopy from "../components/landing/FeatureCopy.astro";
import FeatureSection from "../components/landing/FeatureSection.astro";
import HeroSection from "../components/landing/HeroSection.astro";
import MarketingFooter from "../components/landing/MarketingFooter.astro";
import PluginBuilderSection from "../components/landing/PluginBuilderSection.astro";
import QuickstartSection from "../components/landing/QuickstartSection.astro";
import ResourcesSection from "../components/landing/ResourcesSection.astro";
import StatementSection from "../components/landing/StatementSection.astro";
import { landing } from "../data/landing";

const year = new Date().getFullYear();

function repoParts(githubUrl: string) {
  try {
    const url = new URL(githubUrl);
    const [owner, repo] = url.pathname.split("/").filter(Boolean);
    if (url.hostname !== "github.com" || !owner || !repo) return null;
    return { owner, repo, apiBase: `https://api.github.com/repos/${owner}/${repo}` };
  } catch {
    return null;
  }
}

function formatStars(stars?: number) {
  if (typeof stars !== "number") return undefined;
  if (stars >= 1000) return `${(stars / 1000).toFixed(stars >= 10000 ? 0 : 1)}k stars`;
  return `${stars} star${stars === 1 ? "" : "s"}`;
}

function formatUpdated(date?: string) {
  if (!date) return undefined;
  const parsed = new Date(date);
  if (Number.isNaN(parsed.getTime())) return undefined;
  return `updated ${parsed.toLocaleDateString("en", { month: "short", year: "numeric" })}`;
}

function decodeBase64(value?: string) {
  if (!value) return undefined;
  try {
    return Buffer.from(value, "base64").toString("utf8");
  } catch {
    return undefined;
  }
}

function normalizeAboutText(markdown?: string) {
  if (!markdown) return undefined;

  const lines = markdown.replaceAll("\r\n", "\n").split("\n");
  const headingIndex = lines.findIndex((line) => /^#{1,6}\s+about\s*$/i.test(line.trim()));
  const startIndex = headingIndex >= 0 ? headingIndex + 1 : 0;
  const slice = lines.slice(startIndex);
  const buffer: string[] = [];

  for (const line of slice) {
    const trimmed = line.trim();
    if (!trimmed) {
      if (buffer.length) break;
      continue;
    }
    if (/^#{1,6}\s+/.test(trimmed) && buffer.length) break;
    if (/^#{1,6}\s+about\s*$/i.test(trimmed) && !buffer.length) continue;
    buffer.push(trimmed);
  }

  const text = buffer.join(" ");
  if (!text) return undefined;

  return text
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[`*_>#]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

async function latestRepoVersion(githubUrl: string) {
  const repo = repoParts(githubUrl);
  if (!repo) return undefined;

  try {
    const release = await fetch(`${repo.apiBase}/releases/latest`, {
      headers: {
        Accept: "application/vnd.github+json",
        "User-Agent": "ocelescope-docs",
      },
    });
    if (release.ok) {
      const data = await release.json();
      return data.tag_name || data.name || undefined;
    }
  } catch {
    // Continue with release feed and tag fallbacks.
  }

  try {
    const feed = await fetch(`https://github.com/${repo.owner}/${repo.repo}/releases.atom`, {
      headers: { Accept: "application/atom+xml" },
    });
    if (feed.ok) {
      const text = await feed.text();
      const titles = [...text.matchAll(/<title>\s*([^<]+?)\s*<\/title>/g)].map((match) => match[1]?.trim());
      const title = titles.find((item) => item && !item.toLowerCase().includes("release notes from"));
      if (title) return title;
    }
  } catch {
    // Continue with tag fallback.
  }

  try {
    const tags = await fetch(`${repo.apiBase}/tags?per_page=10`, {
      headers: {
        Accept: "application/vnd.github+json",
        "User-Agent": "ocelescope-docs",
      },
    });
    if (!tags.ok) return undefined;
    const tagList = await tags.json();
    const tag = tagList.find((item: { name?: string }) => typeof item?.name === "string" && item.name.trim());
    return tag?.name || undefined;
  } catch {
    return undefined;
  }
}

async function repoDetails(githubUrl: string) {
  const repo = repoParts(githubUrl);
  if (!repo) return {};

  let description: string | undefined;
  let about: string | undefined;
  let stars: string | undefined;
  let updated: string | undefined;

  try {
    const response = await fetch(repo.apiBase, {
      headers: {
        Accept: "application/vnd.github+json",
        "User-Agent": "ocelescope-docs",
      },
    });
    if (response.ok) {
      const details = await response.json();
      description = details.description || undefined;
      stars = formatStars(details.stargazers_count);
      updated = formatUpdated(details.pushed_at || details.updated_at);
    }
  } catch {
    // Continue with public page metadata fallback.
  }

  try {
    const readmeResponse = await fetch(`${repo.apiBase}/readme`, {
      headers: {
        Accept: "application/vnd.github+json",
        "User-Agent": "ocelescope-docs",
      },
    });
    if (readmeResponse.ok) {
      const readme = await readmeResponse.json();
      about = normalizeAboutText(decodeBase64(readme.content));
    }
  } catch {
    // Leave about unset when GitHub does not expose the README.
  }

  return {
    description,
    about,
    stars,
    updated,
  };
}

const plugins = await Promise.all(
  landing.plugins.map(async (plugin) => ({
    ...plugin,
    ...(await repoDetails(plugin.href)),
    version: await latestRepoVersion(plugin.href),
  })),
);
---

<StarlightPage
  frontmatter={{
    title: landing.meta.title,
    description: landing.meta.description,
    template: "splash",
    pagefind: false,
  }}
  hasSidebar={false}
>
  <div class="landing-shell">
    <HeroSection hero={landing.hero} terminal={landing.terminal} context={landing.context} />

    {landing.features.map((feature) => <FeatureSection feature={feature} />)}

    <StatementSection statement={landing.statement} />
    <PluginBuilderSection content={landing.pluginBuilder} />

    <section class="feature-section feature-light">
      <div class="landing-container feature-grid">
        <FeatureCopy feature={landing.customModule} />
        <BrowserFrame media={landing.customModule.media} />
      </div>
    </section>

    <EcosystemSection ecosystem={landing.ecosystem} plugins={plugins} />
    <ResourcesSection heading={landing.resourcesHeading} groups={landing.resourceGroups} />
    <QuickstartSection quickstart={landing.quickstart} terminal={landing.terminal} />
    <MarketingFooter brand={landing.brand} footer={landing.footer} year={year} />
  </div>

  <script>
    const versionTargets = document.querySelectorAll("[data-github-version]");
    const descriptionTargets = document.querySelectorAll("[data-github-description]");
    const starsTargets = document.querySelectorAll("[data-github-stars]");
    const updatedTargets = document.querySelectorAll("[data-github-updated]");
    const repoDetailsCache = new Map();
    const repoVersionCache = new Map();

    function repoApiBase(githubUrl) {
      try {
        const url = new URL(githubUrl);
        const [owner, repo] = url.pathname.split("/").filter(Boolean);
        if (url.hostname !== "github.com" || !owner || !repo) return null;
        return { owner, repo, apiBase: `https://api.github.com/repos/${owner}/${repo}` };
      } catch {
        return null;
      }
    }

    function formatStars(stars) {
      if (typeof stars !== "number") return null;
      if (stars >= 1000) return `${(stars / 1000).toFixed(stars >= 10000 ? 0 : 1)}k stars`;
      return `${stars} star${stars === 1 ? "" : "s"}`;
    }

    function formatUpdated(date) {
      if (!date) return null;
      const parsed = new Date(date);
      if (Number.isNaN(parsed.getTime())) return null;
      return `updated ${parsed.toLocaleDateString("en", { month: "short", year: "numeric" })}`;
    }

    function decodeBase64(value) {
      if (!value) return null;
      try {
        return atob(value.replace(/\s+/g, ""));
      } catch {
        return null;
      }
    }

    function normalizeAboutText(markdown) {
      if (!markdown) return null;
      const lines = markdown.replace(/\r\n/g, "\n").split("\n");
      const headingIndex = lines.findIndex((line) => /^#{1,6}\s+about\s*$/i.test(line.trim()));
      const startIndex = headingIndex >= 0 ? headingIndex + 1 : 0;
      const buffer = [];

      for (const line of lines.slice(startIndex)) {
        const trimmed = line.trim();
        if (!trimmed) {
          if (buffer.length) break;
          continue;
        }
        if (/^#{1,6}\s+/.test(trimmed) && buffer.length) break;
        if (/^#{1,6}\s+about\s*$/i.test(trimmed) && !buffer.length) continue;
        buffer.push(trimmed);
      }

      const text = buffer.join(" ");
      if (!text) return null;
      return text
        .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
        .replace(/[`*_>#]/g, "")
        .replace(/\s+/g, " ")
        .trim();
    }

    async function repoDetails(githubUrl) {
      if (repoDetailsCache.has(githubUrl)) return repoDetailsCache.get(githubUrl);
      const repo = repoApiBase(githubUrl);
      if (!repo) return null;

      const detailsPromise = (async () => {
        const response = await fetch(repo.apiBase, {
          headers: { Accept: "application/vnd.github+json" },
        });
        if (!response.ok) return null;
        const details = await response.json();

        let about = null;
        try {
          const readmeResponse = await fetch(`${repo.apiBase}/readme`, {
            headers: { Accept: "application/vnd.github+json" },
          });
          if (readmeResponse.ok) {
            const readme = await readmeResponse.json();
            about = normalizeAboutText(decodeBase64(readme.content));
          }
        } catch {
          about = null;
        }

        return {
          description: details.description || null,
          about,
          stars: details.stargazers_count,
          updated: details.pushed_at || details.updated_at,
        };
      })().catch(() => null);

      repoDetailsCache.set(githubUrl, detailsPromise);
      return detailsPromise;
    }

    async function latestRepoVersion(githubUrl) {
      if (repoVersionCache.has(githubUrl)) return repoVersionCache.get(githubUrl);
      const repo = repoApiBase(githubUrl);
      if (!repo) return null;

      const versionPromise = (async () => {
        const release = await fetch(`${repo.apiBase}/releases/latest`, {
          headers: { Accept: "application/vnd.github+json" },
        });
        if (release.ok) {
          const data = await release.json();
          return data.tag_name || data.name || null;
        }

        const feed = await fetch(`https://github.com/${repo.owner}/${repo.repo}/releases.atom`, {
          headers: { Accept: "application/atom+xml" },
        });
        if (feed.ok) {
          const text = await feed.text();
          const titles = [...text.matchAll(/<title>\s*([^<]+?)\s*<\/title>/g)].map((match) => match[1]?.trim());
          const title = titles.find((item) => item && !item.toLowerCase().includes("release notes from"));
          if (title) return title;
        }

        const tags = await fetch(`${repo.apiBase}/tags?per_page=10`, {
          headers: { Accept: "application/vnd.github+json" },
        });
        if (!tags.ok) return null;
        const tagList = await tags.json();
        const tag = tagList.find((item) => typeof item?.name === "string" && item.name.trim());
        return tag?.name || null;
      })().catch(() => null);

      repoVersionCache.set(githubUrl, versionPromise);
      return versionPromise;
    }

    versionTargets.forEach(async (target) => {
      const githubUrl = target.getAttribute("data-github-version");
      if (!githubUrl) return;
      const version = await latestRepoVersion(githubUrl);
      if (version) {
        target.textContent = version;
        target.hidden = false;
      }
    });

    descriptionTargets.forEach(async (target) => {
      const githubUrl = target.getAttribute("data-github-description");
      if (!githubUrl) return;
      const details = await repoDetails(githubUrl);
      const text = details?.description || details?.about;
      if (text) {
        target.textContent = text;
        target.hidden = false;
      }
    });

    starsTargets.forEach(async (target) => {
      const githubUrl = target.getAttribute("data-github-stars");
      if (!githubUrl) return;
      const details = await repoDetails(githubUrl);
      const stars = formatStars(details?.stargazers_count);
      if (stars) {
        target.textContent = stars;
        target.hidden = false;
        target.closest(".plugin-meta")?.removeAttribute("hidden");
      }
    });

    updatedTargets.forEach(async (target) => {
      const githubUrl = target.getAttribute("data-github-updated");
      if (!githubUrl) return;
      const details = await repoDetails(githubUrl);
      const updated = formatUpdated(details?.pushed_at || details?.updated_at);
      if (updated) {
        target.textContent = updated;
        target.hidden = false;
        target.closest(".plugin-meta")?.removeAttribute("hidden");
      }
    });
  </script>

  <script>
    // Scroll-reveal: fade+rise elements in as they enter the viewport.
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add("visible"); io.unobserve(e.target); }
        }),
        { threshold: 0.08, rootMargin: "-32px 0px" }
      );

      const observe = (el: Element, delay = 0) => {
        // Skip elements already in the initial viewport — no flash, no-JS safe
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight * 0.92 && r.bottom > 0) return;
        el.classList.add("reveal");
        if (delay) (el as HTMLElement).style.transitionDelay = delay + "ms";
        io.observe(el);
      };

      // Feature sections: copy and visual enter independently
      document.querySelectorAll(".feature-section .feature-copy").forEach((el) => observe(el));
      document.querySelectorAll(".feature-section .browser-frame").forEach((el) => observe(el, 110));

      // Section headings and title rows
      document.querySelectorAll(".section-heading, .section-title-row").forEach((el) => observe(el));

      // Plugin builder cards (left then right)
      document.querySelectorAll(".builder-grid > *").forEach((el, i) => observe(el, i * 90));

      // Cards: stagger within each visual row (max 3 wide)
      document.querySelectorAll(".card-grid .lift-card").forEach((el, i) => observe(el, (i % 3) * 75));

      // Quickstart CTA
      const qs = document.querySelector(".quickstart-inner");
      if (qs) observe(qs);
    }
  </script>

  <script>
    // Statement section: word-by-word scroll reveal driven by scroll progress.
    const statementSection = document.querySelector<HTMLElement>(".statement-section");
    const statementWords = document.querySelectorAll<HTMLElement>(".statement-word");
    const statementBody = document.querySelector<HTMLElement>(".statement-body");

    if (statementSection && statementWords.length) {
      function updateStatementReveal() {
        const rect = statementSection!.getBoundingClientRect();
        const scrollRange = statementSection!.offsetHeight - window.innerHeight;
        if (scrollRange <= 0) return;
        const progress = Math.max(0, Math.min(1, -rect.top / scrollRange));

        const wordCount = statementWords.length;
        statementWords.forEach((word, i) => {
          // Each word lights up as progress crosses its threshold.
          // Words span from 0..0.85 of progress so the body fades in at the end.
          const threshold = (i / wordCount) * 0.85;
          word.classList.toggle("word-lit", progress >= threshold);
        });

        if (statementBody) {
          statementBody.classList.toggle("body-lit", progress >= 0.88);
        }
      }

      window.addEventListener("scroll", updateStatementReveal, { passive: true });
      updateStatementReveal();
    }
  </script>
</StarlightPage>
