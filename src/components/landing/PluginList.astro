---
import { enrichPlugins } from "../../lib/github";
import { plugins as pluginCatalog } from "../../data/plugins";
import { landing } from "../../data/landing";

const plugins = await enrichPlugins(pluginCatalog);
const cardCta = landing.ecosystem.cardCta;
---

<div class="plugin-list">
  <div class="plugin-search">
    <input
      type="search"
      id="plugin-search-input"
      class="plugin-search-input"
      placeholder="Search by name, author, or description…"
      aria-label="Search plugins"
      autocomplete="off"
    />
  </div>

  <div class="card-grid auto" id="plugin-search-grid">
    {plugins.map((plugin: any, index: number) => (
      <div
        class="plugin-card lift-card"
        data-plugin-name={plugin.name}
        data-plugin-author={plugin.author ?? ""}
        data-plugin-description={plugin.description ?? plugin.about ?? ""}
      >
        <a class="plugin-card-link" href={plugin.href} target="_blank" rel="noreferrer" aria-label={plugin.name}></a>
        <span class={`monogram monogram-${(index % 3) + 1}`}>{plugin.monogram}</span>
        <span class="plugin-card-body">
          <strong>
            {plugin.name}
            <em hidden={!plugin.version}>{plugin.version}</em>
          </strong>
          <span class="plugin-author" hidden={!plugin.author}>by {plugin.author}</span>
          <span class="plugin-about" hidden={!plugin.description && !plugin.about}>{plugin.description ?? plugin.about}</span>
          <span class="plugin-meta" hidden={!plugin.stars && !plugin.updated}>
            <span hidden={!plugin.stars}>{plugin.stars}</span>
            <span hidden={!plugin.updated}>{plugin.updated}</span>
          </span>
          <a
            class="plugin-doi"
            href={plugin.doi ? `https://doi.org/${plugin.doi}` : undefined}
            target="_blank"
            rel="noreferrer"
            hidden={!plugin.doi}
          >
            DOI: {plugin.doi}
          </a>
          <a class="plugin-download" href={plugin.download ?? plugin.href} rel="noreferrer">
            <small>{cardCta} -&gt;</small>
          </a>
        </span>
      </div>
    ))}
  </div>

  <p class="plugin-search-empty" id="plugin-search-empty" hidden>
    No plugins match your search.
  </p>
</div>

<script>
  // Live filter: match the query against each card's name, author, and
  // description, all baked into data- attributes at build time.
  const input = document.getElementById("plugin-search-input") as HTMLInputElement | null;
  const grid = document.getElementById("plugin-search-grid");
  const empty = document.getElementById("plugin-search-empty");

  if (input && grid && empty) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>(".plugin-card")).map(
      (card) => ({
        card,
        haystack: [
          card.dataset.pluginName,
          card.dataset.pluginAuthor,
          card.dataset.pluginDescription,
        ]
          .filter(Boolean)
          .join(" ")
          .toLowerCase(),
      }),
    );

    const apply = () => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;
      for (const { card, haystack } of cards) {
        const match = !query || haystack.includes(query);
        card.hidden = !match;
        if (match) visible += 1;
      }
      empty.hidden = visible > 0;
    };

    input.addEventListener("input", apply);
  }
</script>

<style>
  .plugin-list {
    margin-top: 1.5rem;
  }
  .plugin-search {
    margin-bottom: 1.5rem;
  }
  .plugin-search-input {
    width: 100%;
    padding: 0.7rem 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 10px;
    background: var(--sl-color-black);
    color: var(--sl-color-white);
    font-size: var(--sl-text-body);
  }
  .plugin-search-input:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
  }

  /* Card grid — self-contained so it works on docs pages without landing.css. */
  .card-grid.auto {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .card-grid > * {
    margin-top: 0 !important;
  }

  .plugin-card {
    position: relative;
    display: flex;
    gap: 16px;
    padding: 20px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 14px;
    background: var(--sl-color-gray-6);
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.2s,
      border-color 0.2s;
  }
  .plugin-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--sl-color-accent) 45%, transparent);
    box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.45);
  }
  .plugin-card[hidden] {
    display: none;
  }
  .plugin-card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }
  .monogram {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    color: #fff;
    font: 700 13px var(--sl-font-mono, monospace);
    flex: none;
  }
  .monogram-1 {
    background: linear-gradient(135deg, hsl(192, 82%, 43%), var(--sl-color-accent));
  }
  .monogram-2 {
    background: linear-gradient(135deg, var(--sl-color-accent), hsl(249, 100%, 67%));
  }
  .monogram-3 {
    background: linear-gradient(135deg, hsl(249, 100%, 67%), hsl(192, 82%, 43%));
  }
  .plugin-card-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: var(--sl-color-gray-2);
  }
  .plugin-card strong {
    color: var(--sl-color-white);
  }
  .plugin-card em {
    margin-left: 6px;
    color: var(--sl-color-gray-3);
    font: 500 12px var(--sl-font-mono, monospace);
    font-style: normal;
  }
  .plugin-card [hidden] {
    display: none;
  }
  .plugin-author {
    color: var(--sl-color-gray-3);
    font: 500 12px var(--sl-font-mono, monospace);
  }
  .plugin-about {
    color: var(--sl-color-gray-3);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }
  .plugin-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .plugin-meta span {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    padding: 4px 9px;
    font: 500 11px var(--sl-font-mono, monospace);
  }
  .plugin-doi {
    position: relative;
    z-index: 2;
    align-self: flex-start;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    padding: 4px 9px;
    font: 500 11px var(--sl-font-mono, monospace);
    text-decoration: none;
  }
  .plugin-doi:hover {
    color: var(--sl-color-accent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 45%, transparent);
  }
  .plugin-download {
    position: relative;
    z-index: 2;
    align-self: flex-start;
    margin-top: auto;
    padding-top: 6px;
    text-decoration: none;
  }
  .plugin-download small {
    color: var(--sl-color-accent);
    font-weight: 700;
  }
  .plugin-download:hover small {
    text-decoration: underline;
  }

  .plugin-search-empty {
    color: var(--sl-color-gray-3);
    text-align: center;
    padding: 2rem 0;
  }

  @media (max-width: 640px) {
    .plugin-card {
      flex-direction: column;
    }
  }
</style>
