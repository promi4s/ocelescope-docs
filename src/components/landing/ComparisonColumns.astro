---
interface Column {
	title: string;
	items: string[];
	tone?: "muted" | "accent";
}

interface Props {
	columns: Column[];
}

const { columns } = Astro.props;
---

<div class="comparison-columns not-content">
	{
		columns.map((column) => (
			<section class:list={["comparison-column", column.tone === "accent" && "accent"]}>
				<div>
					<h3>{column.title}</h3>
					<ul>
						{column.items.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
			</section>
		))
	}
</div>

<style>
	.comparison-columns {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		align-items: stretch;
		gap: 1rem;
		margin: 1.5rem 0 2.5rem;
	}

	.comparison-column {
		display: flex;
		flex-direction: column;
		height: 100%;
		min-height: 100%;
		margin: 0;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 8px;
		padding: 1.25rem;
		background: var(--sl-color-black);
	}

	.comparison-column > div {
		display: grid;
		flex: 1;
		grid-template-rows: auto 1fr;
	}

	.comparison-column.accent {
		border-color: var(--sl-color-text-accent);
	}

	.comparison-column::after {
		content: "";
		display: block;
		margin-top: auto;
		padding-top: 1rem;
		border-bottom: 3px solid var(--sl-color-gray-5);
	}

	.comparison-column.accent::after {
		border-bottom-color: var(--sl-color-text-accent);
	}

	h3 {
		margin: 0 0 1rem;
		min-height: 3.4rem;
		color: var(--sl-color-white);
		font-size: var(--sl-text-h4);
		line-height: var(--sl-line-height-headings);
	}

	ul {
		margin: 0;
		padding-inline-start: 1.2rem;
		color: var(--sl-color-gray-2);
	}

	li {
		margin: 0;
	}

	li + li {
		margin-top: 0.55rem;
	}

	@media (max-width: 50rem) {
		.comparison-columns {
			grid-template-columns: 1fr;
		}
	}
</style>
