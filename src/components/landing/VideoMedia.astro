---
interface Props {
    src: string;
    caption?: string;
}

const { src, caption } = Astro.props;
---

<video
    class="video-media"
    src={src}
    autoplay
    loop
    muted
    playsinline
    aria-label={caption}
>
</video>

<style>
    .video-media {
        display: block;
        width: 100%;
        height: auto;
        /* Crisp rendering. Prevents browser from applying bicubic smoothing that
       blurs fine UI text on sub-native display sizes. */
        image-rendering: -webkit-optimize-contrast;
        image-rendering: crisp-edges;
    }
</style>
