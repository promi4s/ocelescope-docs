---
interface Props {
	kicker?: string;
	title: string;
	body?: string;
	statement?: string;
	reverse?: boolean;
}

const { kicker, title, body, statement, reverse = false } = Astro.props;
const hasBodySlot = Astro.slots.has("body");
---

<section class:list={["feature-split", "not-content", reverse && "reverse"]}>
	<div class="copy">
		{kicker && <p class="kicker">{kicker}</p>}
		<h2>{title}</h2>
		{
			hasBodySlot ? (
				<p class="body">
					<slot name="body" />
				</p>
			) : (
				body && <p>{body}</p>
			)
		}
		{statement && <strong>{statement}</strong>}
	</div>
	<div class="visual">
		<slot />
	</div>
</section>

<style>
	.feature-split {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.25fr);
		gap: 2rem;
		align-items: center;
		margin: 3rem 0;
	}

	.feature-split.reverse {
		grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.95fr);
	}

	.feature-split.reverse .copy {
		grid-column: 2;
		grid-row: 1;
	}

	.feature-split.reverse .visual {
		grid-column: 1;
		grid-row: 1;
	}

	.kicker {
		margin: 0 0 0.75rem;
		color: var(--sl-color-text-accent);
		font-size: var(--sl-text-sm);
		font-weight: 800;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		color: var(--sl-color-white);
		font-size: 2.25rem;
		line-height: var(--sl-line-height-headings);
	}

	p,
	.body {
		margin: 1rem 0 0;
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-lg);
		line-height: 1.55;
	}

	strong {
		display: block;
		margin-top: 1.25rem;
		border-inline-start: 3px solid var(--sl-color-text-accent);
		padding-inline-start: 1rem;
		color: var(--sl-color-white);
		font-size: var(--sl-text-lg);
		line-height: 1.45;
	}

	.visual {
		min-width: 0;
	}

	@media (max-width: 62rem) {
		.feature-split,
		.feature-split.reverse {
			grid-template-columns: 1fr;
		}

		.feature-split.reverse .copy,
		.feature-split.reverse .visual {
			grid-column: auto;
			grid-row: auto;
		}
	}
</style>
