---
const { ecosystem, plugins } = Astro.props;
---

<section id="plugins" class="ecosystem-section">
  <div class="landing-container">
    <div class="section-heading">
      <p class="eyebrow">{ecosystem.eyebrow}</p>
      <h2>{ecosystem.title}</h2>
    </div>
    <div class="card-grid two">
      {plugins.map((plugin: any, index: number) => (
        <div class="plugin-card lift-card">
          <a class="plugin-card-link" href={plugin.href} target="_blank" rel="noreferrer" aria-label={plugin.name}></a>
          <span class={`monogram monogram-${(index % 3) + 1}`}>{plugin.monogram}</span>
          <span class="plugin-card-body">
            <strong>
              {plugin.name}
              <em data-github-version={plugin.href} hidden={!plugin.version}>{plugin.version}</em>
            </strong>
            <span class="plugin-author" hidden={!plugin.author}>by {plugin.author}</span>
            <span class="plugin-about" data-github-description={plugin.href} hidden={!plugin.description && !plugin.about}>{plugin.description ?? plugin.about}</span>
            <span class="plugin-meta" hidden={!plugin.stars && !plugin.updated}>
              <span data-github-stars={plugin.href} hidden={!plugin.stars}>{plugin.stars}</span>
              <span data-github-updated={plugin.href} hidden={!plugin.updated}>{plugin.updated}</span>
            </span>
            <a class="plugin-download" href={plugin.download ?? plugin.href} data-github-download={plugin.href} rel="noreferrer">
              <small>{ecosystem.cardCta} -&gt;</small>
            </a>
          </span>
        </div>
      ))}
    </div>
    <div class="ecosystem-cta">
      <a class="button button-primary" href={ecosystem.submit.href}>{ecosystem.submit.label}</a>
      <a class="text-link" href={ecosystem.requestEnv.href}>{ecosystem.requestEnv.label} &rarr;</a>
    </div>
  </div>
</section>
