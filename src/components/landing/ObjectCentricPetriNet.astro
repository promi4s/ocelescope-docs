---
// Static OCPN demo: order/item fulfillment with synchronization + XOR split.
//
// Flow per "run":
//   N items (N random in {2,3,4}) appear at p_received alongside one order.
//   t_inspect fires once per item (non-variable, sequential).
//   Each inspected item randomly picks t_path_a or t_path_b (XOR split).
//   All items converge at p_ready, then t_finalize fires once,
//   consuming the order + all items via a variable arc and producing
//   the order to p_complete.
//
// Three runs are chained into one looping animation so the variability
// (different N, different path choices) is visible.

interface ObjectType {
    id: string;
    label: string;
    color: string;
}
interface Place {
    id: string;
    label?: string;
    objectType: string;
    x: number;
    y: number;
}
interface Transition {
    id: string;
    label: string;
    x: number;
    y: number;
}
interface Arc {
    from: string;
    to: string;
    objectType: string;
    variable?: boolean;
}

const width = 820;
const height = 340;

const objectTypes: ObjectType[] = [
    { id: "order", label: "Order", color: "#f59e0b" },
    { id: "item", label: "Item", color: "#38bdf8" },
];

const places: Place[] = [
    { id: "p_order", objectType: "order", x: 320, y: 60 },
    { id: "p_open", objectType: "order", x: 570, y: 60 },
    { id: "p_complete", objectType: "order", x: 770, y: 60 },
    { id: "p_received", objectType: "item", x: 60, y: 220 },
    {
        id: "p_inspected",
        objectType: "item",
        x: 320,
        y: 220,
    },
    { id: "p_ready", objectType: "item", x: 570, y: 220 },
    {
        id: "p_items_done",
        objectType: "item",
        x: 770,
        y: 220,
    },
];

const transitions: Transition[] = [
    { id: "t_confirm", label: "confirm", x: 445, y: 60 },
    { id: "t_inspect", label: "inspect", x: 190, y: 220 },
    { id: "t_path_a", label: "path A", x: 445, y: 150 },
    { id: "t_path_b", label: "path B", x: 445, y: 290 },
    { id: "t_finalize", label: "finalize", x: 680, y: 140 },
];

const arcs: Arc[] = [
    { from: "p_order", to: "t_confirm", objectType: "order" },
    { from: "t_confirm", to: "p_open", objectType: "order" },
    { from: "p_received", to: "t_inspect", objectType: "item" },
    { from: "t_inspect", to: "p_inspected", objectType: "item" },
    { from: "p_inspected", to: "t_path_a", objectType: "item" },
    { from: "p_inspected", to: "t_path_b", objectType: "item" },
    { from: "t_path_a", to: "p_ready", objectType: "item" },
    { from: "t_path_b", to: "p_ready", objectType: "item" },
    { from: "p_open", to: "t_finalize", objectType: "order" },
    { from: "p_ready", to: "t_finalize", objectType: "item", variable: true },
    { from: "t_finalize", to: "p_complete", objectType: "order" },
    {
        from: "t_finalize",
        to: "p_items_done",
        objectType: "item",
        variable: true,
    },
];

const PL_R = 22;
const TR_W = 12;
const TR_H = 48;

const placeMap = new Map(places.map((p) => [p.id, p]));
const transitionMap = new Map(transitions.map((t) => [t.id, t]));
const colorOf = (otId: string) =>
    objectTypes.find((o) => o.id === otId)?.color ?? "currentColor";

const uid = `ocpn-${Math.random().toString(36).slice(2, 8)}`;

// --- scenario builder ---

type Path = "A" | "B";

const T = {
    intro: 0.4, // items fade in at start of run
    consume: 0.26, // motion: place -> transition
    flash: 0.13, // transition fill flashes during firing
    produce: 0.26, // motion: transition -> place
    interFire: 0.05, // gap between sequential firings
    syncConsume: 0.42, // longer for the sync (multiple items travel in)
    syncProduce: 0.32,
    outro: 0.45, // delivered token visible + fade
};

interface Firing {
    transition: string;
    tConsumeStart: number;
    tConsumeEnd: number;
    tFlashEnd: number;
    tProduceStart: number;
    tProduceEnd: number;
    consumed: { tokenId: string; fromPlace: string }[];
    produced: { tokenId: string; toPlace: string }[];
}

interface Scenario {
    index: number;
    N: number;
    paths: Path[];
    tStart: number;
    tEnd: number;
    orderId: string;
    itemIds: string[];
    firings: Firing[];
}

function makeFiring(
    transition: string,
    start: number,
    dur: { consume: number; produce: number },
    consumed: { tokenId: string; fromPlace: string }[],
    produced: { tokenId: string; toPlace: string }[],
): Firing {
    const tConsumeStart = start;
    const tConsumeEnd = start + dur.consume;
    const tFlashEnd = tConsumeEnd + T.flash;
    const tProduceStart = tFlashEnd;
    const tProduceEnd = tProduceStart + dur.produce;
    return {
        transition,
        tConsumeStart,
        tConsumeEnd,
        tFlashEnd,
        tProduceStart,
        tProduceEnd,
        consumed,
        produced,
    };
}

function buildScenario(index: number, startTime: number): Scenario {
    const N = 2 + Math.floor(Math.random() * 3); // 2, 3, or 4
    const paths: Path[] = Array.from({ length: N }, () =>
        Math.random() < 0.5 ? "A" : "B",
    );
    const orderId = `s${index}-order`;
    const itemIds = Array.from({ length: N }, (_, i) => `s${index}-item-${i}`);

    const firings: Firing[] = [];
    let t = startTime + T.intro;

    // Phase 0: t_confirm — order-only activity at the start of the run.
    const confirm = makeFiring(
        "t_confirm",
        t,
        { consume: T.consume, produce: T.produce },
        [{ tokenId: orderId, fromPlace: "p_order" }],
        [{ tokenId: orderId, toPlace: "p_open" }],
    );
    firings.push(confirm);
    t = confirm.tProduceEnd + T.interFire * 2;

    // Phase 1+2 interleaved: each item runs its full journey
    // (inspect, then XOR route) to p_ready before the next item starts.
    for (let i = 0; i < N; i++) {
        const inspect = makeFiring(
            "t_inspect",
            t,
            { consume: T.consume, produce: T.produce },
            [{ tokenId: itemIds[i], fromPlace: "p_received" }],
            [{ tokenId: itemIds[i], toPlace: "p_inspected" }],
        );
        firings.push(inspect);
        t = inspect.tProduceEnd + T.interFire;

        const trans = paths[i] === "A" ? "t_path_a" : "t_path_b";
        const xor = makeFiring(
            trans,
            t,
            { consume: T.consume, produce: T.produce },
            [{ tokenId: itemIds[i], fromPlace: "p_inspected" }],
            [{ tokenId: itemIds[i], toPlace: "p_ready" }],
        );
        firings.push(xor);
        t = xor.tProduceEnd + T.interFire;
    }

    // Phase 3: finalize — sync of order + all items.
    // Consumes order from p_open and all items from p_ready (variable arc),
    // produces order to p_complete and all items to p_items_done (variable arc).
    const finalize = makeFiring(
        "t_finalize",
        t + 0.15,
        { consume: T.syncConsume, produce: T.syncProduce },
        [
            { tokenId: orderId, fromPlace: "p_open" },
            ...itemIds.map((id) => ({ tokenId: id, fromPlace: "p_ready" })),
        ],
        [
            { tokenId: orderId, toPlace: "p_complete" },
            ...itemIds.map((id) => ({ tokenId: id, toPlace: "p_items_done" })),
        ],
    );
    firings.push(finalize);
    t = finalize.tProduceEnd + T.outro;

    return {
        index,
        N,
        paths,
        tStart: startTime,
        tEnd: t,
        orderId,
        itemIds,
        firings,
    };
}

const SCENARIO_COUNT = 3;
const scenarios: Scenario[] = [];
{
    let t = 0;
    for (let i = 0; i < SCENARIO_COUNT; i++) {
        const s = buildScenario(i, t);
        scenarios.push(s);
        t = s.tEnd;
    }
}
const cycleEnd = scenarios[scenarios.length - 1].tEnd;

// --- offset helpers ---

// Items get a small lane offset so multiple items at the same place don't overlap.
// At places: stack vertically inside the circle.
// At t_finalize (the sync): also stack vertically along the bar.
// At sequential-firing transitions (t_inspect/t_path_*): no offset (one at a time).

function laneOffset(lane: number, count: number, spacing: number) {
    return (lane - (count - 1) / 2) * spacing;
}

interface Pos {
    x: number;
    y: number;
}
function nodeCenter(id: string): Pos & { kind: "place" | "transition" } {
    const p = placeMap.get(id);
    if (p) return { x: p.x, y: p.y, kind: "place" };
    const t = transitionMap.get(id)!;
    return { x: t.x, y: t.y, kind: "transition" };
}

function itemPosAt(nodeId: string, lane: number, scenario: Scenario): Pos {
    const c = nodeCenter(nodeId);
    if (c.kind === "place") {
        return { x: c.x, y: c.y + laneOffset(lane, scenario.N, 8) };
    }
    // transitions
    if (nodeId === "t_finalize") {
        return { x: c.x, y: c.y + laneOffset(lane, scenario.N, 6) };
    }
    return { x: c.x, y: c.y };
}

function orderPosAt(nodeId: string): Pos {
    const c = nodeCenter(nodeId);
    // At t_finalize the order shares the bar with up to 4 items;
    // park it at the top so it doesn't overlap the item cluster.
    if (nodeId === "t_finalize") return { x: c.x, y: c.y - 14 };
    return { x: c.x, y: c.y };
}

// --- per-token visit construction ---

interface Visit {
    x: number;
    y: number;
    tArrive: number;
    tLeave: number;
}
interface OpStop {
    t: number;
    v: number;
}
interface Token {
    id: string;
    color: string;
    size: number;
    visits: Visit[];
    opacity: OpStop[];
}

const tokens: Token[] = [];

for (const s of scenarios) {
    // Order token: p_order -> t_confirm -> p_open -> t_finalize -> p_complete
    const confirmFiring = s.firings.find((f) => f.transition === "t_confirm")!;
    const finalize = s.firings[s.firings.length - 1];
    const orderVisits: Visit[] = [];
    orderVisits.push({
        ...orderPosAt("p_order"),
        tArrive: s.tStart,
        tLeave: confirmFiring.tConsumeStart,
    });
    orderVisits.push({
        ...orderPosAt("t_confirm"),
        tArrive: confirmFiring.tConsumeEnd,
        tLeave: confirmFiring.tProduceStart,
    });
    orderVisits.push({
        ...orderPosAt("p_open"),
        tArrive: confirmFiring.tProduceEnd,
        tLeave: finalize.tConsumeStart,
    });
    orderVisits.push({
        ...orderPosAt("t_finalize"),
        tArrive: finalize.tConsumeEnd,
        tLeave: finalize.tProduceStart,
    });
    orderVisits.push({
        ...orderPosAt("p_complete"),
        tArrive: finalize.tProduceEnd,
        tLeave: s.tEnd,
    });

    tokens.push({
        id: s.orderId,
        color: colorOf("order"),
        size: 4.2,
        visits: orderVisits,
        opacity: [
            { t: 0, v: 0 },
            { t: s.tStart, v: 0 },
            { t: s.tStart + 0.1, v: 1 },
            { t: s.tEnd - 0.2, v: 1 },
            { t: s.tEnd - 0.05, v: 0 },
            { t: cycleEnd, v: 0 },
        ],
    });

    // Item tokens
    for (let i = 0; i < s.N; i++) {
        const tokenId = s.itemIds[i];
        const visits: Visit[] = [];

        // Sit at p_received from tStart until first inspect firing for this item
        const inspectFiring = s.firings.find(
            (f) =>
                f.transition === "t_inspect" &&
                f.consumed.some((c) => c.tokenId === tokenId),
        )!;
        visits.push({
            ...itemPosAt("p_received", i, s),
            tArrive: s.tStart,
            tLeave: inspectFiring.tConsumeStart,
        });
        // At t_inspect (centered, single-item firing)
        visits.push({
            ...itemPosAt("t_inspect", 0, s),
            tArrive: inspectFiring.tConsumeEnd,
            tLeave: inspectFiring.tProduceStart,
        });

        // Sit at p_inspected until this item's XOR firing
        const xorFiring = s.firings.find(
            (f) =>
                (f.transition === "t_path_a" || f.transition === "t_path_b") &&
                f.consumed.some((c) => c.tokenId === tokenId),
        )!;
        visits.push({
            ...itemPosAt("p_inspected", i, s),
            tArrive: inspectFiring.tProduceEnd,
            tLeave: xorFiring.tConsumeStart,
        });
        // At XOR transition (centered)
        visits.push({
            ...itemPosAt(xorFiring.transition, 0, s),
            tArrive: xorFiring.tConsumeEnd,
            tLeave: xorFiring.tProduceStart,
        });
        // Sit at p_ready until finalize
        visits.push({
            ...itemPosAt("p_ready", i, s),
            tArrive: xorFiring.tProduceEnd,
            tLeave: finalize.tConsumeStart,
        });
        // Travel through t_finalize (consumed AND produced — passes through sync)
        visits.push({
            ...itemPosAt("t_finalize", i, s),
            tArrive: finalize.tConsumeEnd,
            tLeave: finalize.tProduceStart,
        });
        // Arrive at the item sink p_items_done
        visits.push({
            ...itemPosAt("p_items_done", i, s),
            tArrive: finalize.tProduceEnd,
            tLeave: s.tEnd,
        });

        tokens.push({
            id: tokenId,
            color: colorOf("item"),
            size: 4,
            visits,
            opacity: [
                { t: 0, v: 0 },
                { t: s.tStart, v: 0 },
                { t: s.tStart + 0.15, v: 1 },
                { t: s.tEnd - 0.2, v: 1 },
                { t: s.tEnd - 0.05, v: 0 },
                { t: cycleEnd, v: 0 },
            ],
        });
    }
}

// --- compile each token to SMIL animateMotion + opacity ---

const fmt = (n: number) => Math.max(0, Math.min(1, n)).toFixed(4);
const clampT = (t: number) => Math.max(0, Math.min(cycleEnd, t));

interface Compiled {
    path: string;
    keyTimes: string;
    keyPoints: string;
    opKeyTimes: string;
    opValues: string;
}

function compile(tok: Token): Compiled {
    const v = tok.visits;
    const pathParts: string[] = [`M ${v[0].x} ${v[0].y}`];
    const segLens: number[] = [];
    let total = 0;
    for (let i = 1; i < v.length; i++) {
        pathParts.push(`L ${v[i].x} ${v[i].y}`);
        const len = Math.hypot(v[i].x - v[i - 1].x, v[i].y - v[i - 1].y);
        segLens.push(len);
        total += len;
    }
    const cumFrac: number[] = [0];
    let cum = 0;
    for (const l of segLens) {
        cum += l;
        cumFrac.push(total > 0 ? cum / total : 0);
    }

    const kt: number[] = [];
    const kp: number[] = [];
    for (let i = 0; i < v.length; i++) {
        const tA = clampT(v[i].tArrive) / cycleEnd;
        const tL = clampT(v[i].tLeave) / cycleEnd;
        if (kt.length === 0 || tA > kt[kt.length - 1] + 1e-6) {
            kt.push(tA);
            kp.push(cumFrac[i]);
        }
        if (tL > tA + 5e-4) {
            kt.push(tL);
            kp.push(cumFrac[i]);
        }
    }
    if (kt[0] > 0) {
        kt.unshift(0);
        kp.unshift(cumFrac[0]);
    }
    if (kt[kt.length - 1] < 1) {
        kt.push(1);
        kp.push(cumFrac[cumFrac.length - 1]);
    }

    const op = [...tok.opacity].sort((a, b) => a.t - b.t);
    const opKT: number[] = [];
    const opV: number[] = [];
    for (const s of op) {
        const t = clampT(s.t) / cycleEnd;
        if (opKT.length === 0 || t > opKT[opKT.length - 1] + 1e-6) {
            opKT.push(t);
            opV.push(s.v);
        } else {
            opV[opV.length - 1] = s.v;
        }
    }
    if (opKT[0] > 0) {
        opKT.unshift(0);
        opV.unshift(op[0].v);
    }
    if (opKT[opKT.length - 1] < 1) {
        opKT.push(1);
        opV.push(op[op.length - 1].v);
    }

    return {
        path: pathParts.join(" "),
        keyTimes: kt.map(fmt).join(";"),
        keyPoints: kp.map(fmt).join(";"),
        opKeyTimes: opKT.map(fmt).join(";"),
        opValues: opV.map((x) => x.toString()).join(";"),
    };
}

const compiledTokens = tokens.map((t) => ({ tok: t, c: compile(t) }));

// --- transition flash schedule across all scenarios ---

interface FlashEvent {
    t: number;
    duration: number;
}
const transitionFlashes: Record<string, FlashEvent[]> = {};
for (const s of scenarios) {
    for (const f of s.firings) {
        const arr =
            transitionFlashes[f.transition] ??
            (transitionFlashes[f.transition] = []);
        arr.push({
            t: f.tConsumeEnd + 0.005,
            duration: f.tFlashEnd - f.tConsumeEnd - 0.01,
        });
    }
}

function flashAttrs(events: FlashEvent[]) {
    if (!events.length) return null;
    const sorted = [...events].sort((a, b) => a.t - b.t);
    const kt: number[] = [0];
    const vals: string[] = ["var(--sl-color-gray-6)"];
    for (const e of sorted) {
        const t0 = clampT(e.t) / cycleEnd;
        const t1 = clampT(e.t + e.duration) / cycleEnd;
        if (t0 > kt[kt.length - 1]) {
            kt.push(t0);
            vals.push("var(--sl-color-gray-6)");
        }
        kt.push(Math.min(1, t0 + 1e-4));
        vals.push("var(--sl-color-text-accent)");
        kt.push(t1);
        vals.push("var(--sl-color-text-accent)");
        kt.push(Math.min(1, t1 + 1e-4));
        vals.push("var(--sl-color-gray-6)");
    }
    if (kt[kt.length - 1] < 1) {
        kt.push(1);
        vals.push("var(--sl-color-gray-6)");
    }
    return {
        keyTimes: kt.map(fmt).join(";"),
        values: vals.join(";"),
    };
}

// --- arc geometry: trim to node edges ---

function trim(
    x1: number,
    y1: number,
    x2: number,
    y2: number,
    rStart: number,
    rEnd: number,
) {
    const dx = x2 - x1;
    const dy = y2 - y1;
    const len = Math.hypot(dx, dy) || 1;
    const ux = dx / len;
    const uy = dy / len;
    return {
        x1: x1 + ux * rStart,
        y1: y1 + uy * rStart,
        x2: x2 - ux * rEnd,
        y2: y2 - uy * rEnd,
    };
}

function nodeRadius(id: string, isVertical: boolean): number {
    if (placeMap.has(id)) return PL_R;
    return isVertical ? TR_H / 2 : TR_W / 2;
}

const renderedArcs = arcs.map((a) => {
    const from = placeMap.get(a.from) ?? transitionMap.get(a.from)!;
    const to = placeMap.get(a.to) ?? transitionMap.get(a.to)!;
    const dx = to.x - from.x;
    const dy = to.y - from.y;
    const horizontal = Math.abs(dx) >= Math.abs(dy);
    const rFrom = nodeRadius(a.from, !horizontal) + 1;
    const rTo = nodeRadius(a.to, !horizontal) + 5;
    const t = trim(from.x, from.y, to.x, to.y, rFrom, rTo);
    return {
        ...a,
        variable: !!a.variable,
        tx1: t.x1,
        ty1: t.y1,
        tx2: t.x2,
        ty2: t.y2,
    };
});
---

<figure class="ocpn not-content">
    <svg
        viewBox={`0 0 ${width} ${height}`}
        width="100%"
        role="img"
        aria-label="Animated object-centric Petri net: order and item synchronization with XOR split"
        preserveAspectRatio="xMidYMid meet"
    >
        <defs>
            {
                objectTypes.map((ot) => (
                    <marker
                        id={`${uid}-arrow-${ot.id}`}
                        viewBox="0 0 10 10"
                        refX="9"
                        refY="5"
                        markerWidth="6"
                        markerHeight="6"
                        orient="auto-start-reverse"
                    >
                        <path d="M 0 2 L 9 5 L 0 8 z" fill={ot.color} />
                    </marker>
                ))
            }
        </defs>

        {
            renderedArcs.map((a) => (
                <line
                    x1={a.tx1}
                    y1={a.ty1}
                    x2={a.tx2}
                    y2={a.ty2}
                    stroke={colorOf(a.objectType)}
                    stroke-width={a.variable ? 3.4 : 1.6}
                    stroke-linecap="round"
                    marker-end={`url(#${uid}-arrow-${a.objectType})`}
                />
            ))
        }

        {
            places.map((p) => (
                <circle
                    cx={p.x}
                    cy={p.y}
                    r={PL_R}
                    class="ocpn-place"
                    stroke={colorOf(p.objectType)}
                />
            ))
        }

        {
            transitions.map((t) => {
                const attrs = flashAttrs(transitionFlashes[t.id] ?? []);
                return (
                    <g>
                        <rect
                            x={t.x - TR_W / 2}
                            y={t.y - TR_H / 2}
                            width={TR_W}
                            height={TR_H}
                            rx="2"
                            class="ocpn-transition"
                        >
                            {attrs && (
                                <animate
                                    attributeName="fill"
                                    dur={`${cycleEnd}s`}
                                    repeatCount="indefinite"
                                    keyTimes={attrs.keyTimes}
                                    values={attrs.values}
                                />
                            )}
                        </rect>
                        <text
                            x={t.x}
                            y={t.y - TR_H / 2 - 10}
                            text-anchor="middle"
                            class="ocpn-transition-label"
                        >
                            {t.label}
                        </text>
                    </g>
                );
            })
        }

        {
            compiledTokens.map(({ tok, c }) => (
                <circle r={tok.size} fill={tok.color} opacity="0">
                    <animateMotion
                        dur={`${cycleEnd}s`}
                        repeatCount="indefinite"
                        path={c.path}
                        keyTimes={c.keyTimes}
                        keyPoints={c.keyPoints}
                        calcMode="linear"
                    />
                    <animate
                        attributeName="opacity"
                        dur={`${cycleEnd}s`}
                        repeatCount="indefinite"
                        keyTimes={c.opKeyTimes}
                        values={c.opValues}
                    />
                </circle>
            ))
        }
    </svg>

    <ul class="ocpn-legend">
        {
            objectTypes.map((ot) => (
                <li>
                    <span class="dot" style={`background:${ot.color};`} />
                    {ot.label}
                </li>
            ))
        }
    </ul>
</figure>

<style>
    .ocpn {
        display: grid;
        gap: 1rem;
        margin: 0;
        background: var(--sl-color-bg);
    }

    .ocpn svg {
