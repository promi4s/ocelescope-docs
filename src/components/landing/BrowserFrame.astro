---
import TrafficLights from "./TrafficLights.astro";

const { media } = Astro.props;

const isVideo = media.src && /\.(mp4|webm|mov)$/i.test(media.src);
const isImage = media.src && /\.(png|jpe?g|gif|webp|avif|svg)$/i.test(media.src);
---

<div class="browser-frame">
  <div class="window-bar light"><TrafficLights /><span>{media.url}</span></div>
  {isVideo ? (
    <video class="browser-media" src={media.src} autoplay loop muted playsinline aria-label={media.caption} />
  ) : isImage ? (
    <img class="browser-media" src={media.src} alt={media.caption} loading="lazy" />
  ) : (
    <div class="browser-placeholder">
      <button type="button" class="play-button" aria-label={media.playLabel ?? `Play ${media.caption}`}>
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path d="M9 7l9 5-9 5V7z" fill="currentColor" /></svg>
      </button>
      <span class="media-caption">{media.caption}</span>
    </div>
  )}
</div>
